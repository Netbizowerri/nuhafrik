{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's full name." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "role": { "type": "string", "enum": ["admin", "customer"], "description": "User's role in the system." },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp when the profile was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Represents a clothing item in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product." },
        "description": { "type": "string", "description": "Detailed description of the product." },
        "price": { "type": "number", "description": "Price of the product." },
        "image": { "type": "string", "description": "Base64 encoded image string." },
        "category_id": { "type": "string", "description": "ID of the category the product belongs to." },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp when the product was added." }
      },
      "required": ["name", "price", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer purchase.",
      "type": "object",
      "properties": {
        "customer": {
          "type": "object",
          "properties": {
            "uid": { "type": "string" },
            "email": { "type": "string" },
            "name": { "type": "string" }
          }
        },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["customer", "items", "total", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of store products."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders."
    }
  }
}
