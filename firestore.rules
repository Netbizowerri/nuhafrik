rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdminEmail() {
      return isAuthenticated() &&
        request.auth.token.email == "nuhafrikclothings@gmail.com";
    }

    function isAdminProfile() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdmin() {
      return isAdminProfile() || isAdminEmail();
    }

    function isOrderOwner(orderData) {
      return isAuthenticated() && orderData.customer.uid == request.auth.uid;
    }

    function isValidOrderStatus(status) {
      return status == 'confirmed' ||
        status == 'processing' ||
        status == 'shipped' ||
        status == 'out_for_delivery' ||
        status == 'delivered' ||
        status == 'cancelled';
    }

    function isValidOrderCreate() {
      let data = request.resource.data;

      return data.keys().hasOnly([
          'order_number',
          'customer',
          'items',
          'pricing',
          'delivery',
          'payment_method',
          'status',
          'created_at'
        ]) &&
        data.order_number is string &&
        data.customer is map &&
        data.customer.uid is string &&
        data.customer.name is string &&
        data.customer.phone is string &&
        (!('email' in data.customer) || data.customer.email == null || data.customer.email is string) &&
        data.items is list &&
        data.items.size() > 0 &&
        data.pricing is map &&
        data.pricing.subtotal is number &&
        data.pricing.delivery_fee is number &&
        data.pricing.discount is number &&
        data.pricing.total is number &&
        data.pricing.currency is string &&
        data.delivery is map &&
        data.delivery.method is string &&
        data.delivery.estimated_date is timestamp &&
        (!('address' in data.delivery) || data.delivery.address == null || data.delivery.address is string) &&
        data.payment_method is string &&
        isValidOrderStatus(data.status) &&
        data.created_at is timestamp;
    }

    function isValidUserProfileWrite(userId) {
      let data = request.resource.data;

      return data.uid == userId &&
        (!('email' in data) || data.email == null || data.email is string) &&
        (!('displayName' in data) || data.displayName == null || data.displayName is string) &&
        (!('name' in data) || data.name == null || data.name is string) &&
        (!('phone' in data) || data.phone == null || data.phone is string) &&
        (!('photoURL' in data) || data.photoURL == null || data.photoURL is string) &&
        (!('role' in data) ||
          data.role == 'customer' ||
          (data.role == 'admin' && isAdminEmail()));
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isValidOrderCreate();
      allow read: if isAdmin() || isOrderOwner(resource.data);
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create, update: if (isSelf(userId) && isValidUserProfileWrite(userId)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
